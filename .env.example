# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
ROUTER_MODEL=claude-haiku-4-5-20251001
SQL_MODEL=claude-sonnet-5
SYNTHESIS_MODEL=claude-sonnet-5

# --- Database (SQLite by default; point at SQL Server via a proper DSN in prod) ---
# SQL Server example:
#   DATABASE_URL=mssql+pyodbc://readonly_user:password@your-server/NorthwindRetail?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=sqlite:///./data/northwind_retail.db

# --- Vector store ---
CHROMA_PERSIST_DIR=./vector_store
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Demo user (replace with a real user store / IdP in production)
DEMO_USERNAME=analyst
DEMO_PASSWORD=changeme123

# --- Safety limits ---
SQL_MAX_ROWS=500
SQL_TIMEOUT_SECONDS=10
